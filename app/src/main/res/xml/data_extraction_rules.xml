<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <include domain="file" path="workspace/MEMORY.md"/>
        <include domain="file" path="workspace/HISTORY.md"/>
        <include domain="sharedpref" path="nanobot_config.xml"/>
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="workspace/"/>
        <include domain="sharedpref" path="nanobot_config.xml"/>
    </device-transfer>
</data-extraction-rules>
